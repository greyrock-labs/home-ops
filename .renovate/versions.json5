{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets//versioning/searxng.json5#2.0.1",
  ],
  packageRules: [
    {
      description: ["Loose versioning for bambuddy"],
      matchDatasources: ["docker"],
      allowedVersions: "/^\\d+\\.\\d+\\.\\d+(\\.\\d+)?$/",
      versioning: "loose",
      matchPackageNames: ["ghcr.io/maziggy/bambuddy"],
    },
    {
      description: ["Regex versioning for scrypted"],
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/koush/scrypted"],
      versioning: "regex:^v(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-(?<compatibility>.+)$",
    },
  ],
}
