{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "local>greyrock-labs/renovate-config",
    "local>greyrock-labs/home-ops//.renovate/customManagers.json5",
    "local>greyrock-labs/home-ops//.renovate/groups.json5",
    "local>greyrock-labs/home-ops//.renovate/autoMerge.json5",
    "local>greyrock-labs/home-ops//.renovate/versions.json5",
    "local>greyrock-labs/home-ops//.renovate/overrides.json5",
  ],
  flux: {
    managerFilePatterns: ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/^kubernetes/.+\\.yaml(?:\\.j2)?$/"],
  },
}
